{
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter dxf-vuer-demo dev",
    "build": "pnpm --filter dxf-render build && pnpm --filter dxf-vuer build",
    "build:demo": "pnpm --filter dxf-vuer-demo build",
    "preview": "pnpm --filter dxf-vuer-demo preview",
    "test": "pnpm -r --parallel run test",
    "test:watch": "pnpm -r --parallel run test -- --watch"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "~5.9.3"
  }
}
